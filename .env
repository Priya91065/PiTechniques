# =============================================================================
# Pi Techniques — Environment Variables
# Copy this file to `.env` and fill in real values.  NEVER commit `.env`.
#   cp .env.example .env
# Variables are validated at runtime by src/lib/env.ts (zod).
# =============================================================================

# ---- Application -----------------------------------------------------------
NODE_ENV=development
# Public base URL of the site (used for canonical URLs, OG tags, sitemap).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Database: PostgreSQL (configured in Phase 2) --------------------------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Pooled (host has "-pooler") — used by the app at runtime.
DATABASE_URL="postgresql://neondb_owner:npg_ytBfFPUOi8I4@ep-floral-surf-atilt6a3-pooler.c-9.us-east-1.aws.neon.tech/neondb?channel_binding=require&sslmode=require"
# DATABASE_URL="postgresql://neondb_owner:npg_ytBfFPUOi8I4@ep-floral-surf-atilt6a3-pooler.c-9.us-east-1.aws.neon.tech/neondb?sslmode=require"
# DIRECT_URL is used by Prisma Migrate when DATABASE_URL points at a connection
# pooler (e.g. Neon/Supabase/PgBouncer). This is the UNPOOLED string (no "-pooler").
DIRECT_URL="postgresql://neondb_owner:npg_ytBfFPUOi8I4@ep-floral-surf-atilt6a3.c-9.us-east-1.aws.neon.tech/neondb?sslmode=require"

# ---- Authentication: JWT (configured in Phase 3) --------------------------
# Generate strong secrets, e.g.:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET="6lFO-U4Nx4kWPo67deez8rmP4w_bpNkgKxm6ZWOC-gsWFB8PXKynEHU6zxeHfvuc"
JWT_REFRESH_SECRET="la4u0YCIhPTGb6Ep89IqSAf_n4HT6BBrElaW7zVRXmBRnQ4Ed4mOozkLKcVuRU_0"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"
# bcrypt cost factor (10–15; higher = slower & safer).
BCRYPT_ROUNDS=12

# ---- Media uploads (configured in Phase 5) --------------------------------
UPLOAD_DIR="public/uploads"
MAX_UPLOAD_MB=10

# ---- Seed / bootstrap Super Admin (configured in Phase 2/3) ---------------
SEED_SUPERADMIN_EMAIL="admin@pitechniques.com"
SEED_SUPERADMIN_PASSWORD="ChangeMe!2025"
SEED_SUPERADMIN_NAME="Super Admin"
