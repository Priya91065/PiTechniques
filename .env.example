# =============================================================================
# Pi Techniques — Environment Variables
# Copy this file to `.env` and fill in real values.  NEVER commit `.env`.
#   cp .env.example .env
# Variables are validated at runtime by src/lib/env.ts (zod).
# =============================================================================

# ---- Application -----------------------------------------------------------
NODE_ENV=development
# Public base URL of the site (used for canonical URLs, OG tags, sitemap).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Database: PostgreSQL (configured in Phase 2) --------------------------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
#
# PRODUCTION (Vercel + Neon/Supabase): set BOTH of these in the Vercel project's
# Environment Variables (Settings → Environment Variables), NOT in this file —
# .env is git-ignored and never ships to Vercel.
#   • DATABASE_URL → the POOLED connection string (host contains "-pooler",
#     append ?sslmode=require&pgbouncer=true). Used by the app at runtime; the
#     pooler is required for serverless so connections aren't exhausted.
#   • DIRECT_URL   → the DIRECT (non-pooled) connection string (?sslmode=require).
#     Used by `prisma migrate deploy`; migrations cannot run through a pooler.
# Example (Neon):
#   DATABASE_URL="postgresql://USER:PASS@ep-xxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
#   DIRECT_URL="postgresql://USER:PASS@ep-xxx.REGION.aws.neon.tech/neondb?sslmode=require"
#
# LOCAL DEV: a plain local Postgres works for both; keep them identical.
DATABASE_URL="postgresql://pi_admin:pi_password@localhost:5432/pitechniques?schema=public"
DIRECT_URL="postgresql://pi_admin:pi_password@localhost:5432/pitechniques?schema=public"

# ---- Authentication: JWT (configured in Phase 3) --------------------------
# Generate strong secrets, e.g.:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET="replace-with-a-long-random-string-min-32-chars"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-string-min-32-chars"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"
# bcrypt cost factor (10–15; higher = slower & safer).
BCRYPT_ROUNDS=12

# ---- Media uploads (configured in Phase 5) --------------------------------
UPLOAD_DIR="public/uploads"
MAX_UPLOAD_MB=10
# PRODUCTION (Vercel): set BLOB_READ_WRITE_TOKEN (Vercel → Storage → Blob) so
# uploads go to Vercel Blob and persist across deploys. Vercel's filesystem is
# read-only/ephemeral, so local-disk uploads do NOT work there. When this is
# unset (local dev), uploads use UPLOAD_DIR on disk.
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ---- Seed / bootstrap Super Admin (configured in Phase 2/3) ---------------
SEED_SUPERADMIN_EMAIL="admin@pitechniques.com"
SEED_SUPERADMIN_PASSWORD="ChangeMe!2025"
SEED_SUPERADMIN_NAME="Super Admin"
